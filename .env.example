# Discord bot token (Bot section in Discord Developer Portal)
DISCORD_TOKEN=

# Path to Google service account JSON key file
GOOGLE_APPLICATION_CREDENTIALS=

# Spreadsheet ID from the URL: https://docs.google.com/spreadsheets/d/<THIS_PART>/edit
SPREADSHEET_ID=

# Optional: only these Discord servers (guild IDs, comma-separated). Leave unset for any server + DMs.
# ALLOWED_GUILD_IDS=123456789012345678
# Optional: only these channels (comma-separated numeric IDs). Leave unset for all channels in allowed guilds.
# ALLOWED_CHANNEL_IDS=123456789012345678,987654321098765432

# Set to 1 to print raw + parsed rows to the terminal instead of calling Google Sheets (for Discord testing).
# CBSC_SHEETS_DRY_RUN=1
